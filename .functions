# CHEAT
cheat () {
    if [ -z "$1" ]; then
        echo "Usage : cheat <commande>"
        return 1
    fi
    curl "cheat.sh/$1"
}

# HISTORY GREP
hg () {
    if [ -z "$1" ]; then
        echo "Usage : hg <motif>"
        return 1
    fi
    history | grep "$1"
}

# CLEAN
# Supprime tout le contenu du dossier courant (fichiers cachés inclus), après confirmation
clean () {
    printf 'Supprimer tout le contenu de %s (y compris les fichiers cachés) ? [y/N] ' "$PWD"
    read -r reply
    if [[ "$reply" =~ ^[Yy]$ ]]; then
        find . -mindepth 1 -maxdepth 1 -exec rm -rf {} +
    else
        echo "Annulé."
    fi
}

# EXTRACT
# Extrait les fichiers archivés
extract () {
    if [ -z "$1" ]; then
        echo "Usage : extract <archive>"
        return 1
    fi
    if [ -f "$1" ]; then
        case "$1" in
            *.tar.bz2)  tar -jxvf "$1"                       ;;
            *.tar.gz)   tar -zxvf "$1"                       ;;
            *.tar.xz)   tar -Jxvf "$1"                       ;;
            *.bz2)      bunzip2 "$1"                         ;;
            *.gz)       gunzip "$1"                          ;;
            *.tar)      tar -xvf "$1"                        ;;
            *.tbz2)     tar -jxvf "$1"                       ;;
            *.tgz)      tar -zxvf "$1"                       ;;
            *.zip)      unzip "$1"                           ;;
            *.7z)       7z x "$1"                            ;;
            *.rar)      unrar x "$1"                         ;;
            *)          echo "'$1' ne peut pas être extrait via extract()" ;;
        esac
    else
        echo "'$1' n'est pas un fichier valide"
    fi
}

# MKDIRCD
# Crée un dossier et s'y déplace
function mkdircd () {
   if [ -z "$1" ]; then
       echo "Usage : mkdircd <dossier>"
       return 1
   fi
   mkdir "$@" && cd "$@"
}

# UPDATE
# Met à jour le dépôt dotfiles (symlinké dans $HOME par install.sh) et recharge le shell
function update-terminal () {
    local dotfiles_dir
    dotfiles_dir="$(dirname "$(readlink -f ~/.zshrc)")"

    if [[ -d "$dotfiles_dir/.git" ]]; then
        git -C "$dotfiles_dir" pull --ff-only && source ~/.zshrc
    else
        echo "Impossible de localiser le dépôt dotfiles (~/.zshrc n'est pas un lien symbolique valide)"
    fi
}